<div class="flex items-start" data-controller="sidebar">
  <div data-sidebar-target="showButton"
       class="hidden sticky top-6 self-start w-0 shrink-0">
    <button type="button"
            data-action="sidebar#toggle"
            class="absolute -left-10 top-0 bg-white border border-gray-200 hover:bg-gray-50 text-gray-500 hover:text-sky-700 rounded-lg p-2 shadow-sm"
            title="Show quick access">»</button>
  </div>

  <aside data-sidebar-target="aside"
         class="relative z-10 w-56 shrink-0 self-start sticky top-6 mr-6 transition-all duration-200 ease-out">
    <button type="button"
            data-action="sidebar#toggle"
            class="absolute -left-10 top-0 bg-white border border-gray-200 hover:bg-gray-50 text-gray-500 hover:text-sky-700 rounded-lg p-2 shadow-sm"
            title="Hide quick access">«</button>
    <div class="max-h-screen overflow-x-hidden overflow-y-auto bg-white border border-gray-200 rounded-lg p-2">
    <label class="flex items-center gap-1.5 mb-1.5 pb-1.5 border-b border-gray-200 text-xs text-gray-500 cursor-pointer select-none">
      <input type="checkbox"
             data-sidebar-target="anchorToggle"
             data-action="sidebar#toggleAnchor"
             class="accent-sky-600 cursor-pointer">
      <span>Highlight on scroll</span>
    </label>
    <% if @categorized_endpoints.any? %>
      <div>
        <div class="text-xs font-bold uppercase tracking-wide text-gray-700 mb-1">Endpoints</div>
        <% @categorized_endpoints.group_by(&:path).each_with_index do |(path, group), i| %>
          <div class="<%= "mt-1 pt-1 border-t border-gray-200" if i > 0 %>">
            <% group.each do |endpoint| %>
              <% tint = { "added" => "bg-emerald-50 text-emerald-700", "removed" => "bg-red-50 text-red-700 line-through", "changed" => "bg-amber-50 text-amber-700" }[endpoint.annotation] || "text-gray-700" %>
              <a href="<%= "#endpoint-#{endpoint.page_url}" %>"
                 title="<%= endpoint.name %>"
                 data-sidebar-target="link"
                 class="flex items-center gap-1.5 px-1 py-0.5 rounded <%= tint %> hover:bg-gray-50">
                <%= render "endpoints/verb_badge", verb: endpoint.verb %>
                <span class="min-w-0 truncate text-sm font-mono"><%= endpoint.path %></span>
                <span id="<%= sidebar_count_dom_id(endpoint_sidebar_anchor(endpoint)) %>" class="ml-auto shrink-0"><%= comment_count_badge(endpoint_comment_thread_count(endpoint)) %></span>
              </a>
            <% end %>
          </div>
        <% end %>
      </div>
    <% end %>

    <% if @categorized_entities.any? %>
      <div class="<%= "mt-2 pt-2 border-t border-gray-200" if @categorized_endpoints.any? %>">
        <div class="text-xs font-bold uppercase tracking-wide text-gray-700 mb-1">Entities</div>
        <% @categorized_entities.each do |entity| %>
          <% tint = { "added" => "bg-emerald-50 text-emerald-700 font-semibold", "removed" => "bg-red-50 text-red-700 font-semibold line-through", "changed" => "bg-amber-50 text-amber-700 font-semibold" }[entity.annotation] || "text-gray-700" %>
          <a href="<%= "#entity-#{entity.name}" %>"
             title="<%= entity.name %>"
             data-sidebar-target="link"
             class="flex items-center gap-1.5 px-2 py-1 rounded text-sm <%= tint %> hover:bg-gray-50 hover:text-sky-700">
            <span class="min-w-0 truncate"><%= entity.name %></span>
            <span id="<%= sidebar_count_dom_id(entity_sidebar_anchor(entity)) %>" class="ml-auto shrink-0"><%= comment_count_badge(entity_comment_thread_count(entity)) %></span>
          </a>
        <% end %>
      </div>
    <% end %>
    </div>
  </aside>

  <div class="flex-1 min-w-0">
    <% if block_given? %>
      <%= yield %>
    <% end %>

    <%# Endpoints %>
    <% if @categorized_endpoints.any? %>
      <div class="text-xl font-semibold text-black uppercase tracking-wide mb-6">Endpoints</div>
      <div class="flex flex-col gap-10">
        <% @categorized_endpoints.each do |endpoint| %>
          <% endpoint_anchor = CommentAnchor.new(scope: "endpoint", part: "whole", endpoint_path: endpoint.path, endpoint_http_verb: Endpoint.http_verbs[endpoint.http_verb]) %>
          <div id="endpoint-<%= endpoint.page_url %>" <%= comment_region_attr(endpoint_anchor) %> data-sidebar-target="card" class="scroll-mt-6 rounded-xl">
            <% if endpoint.annotation == "unchanged" || endpoint.annotation == "changed" %>
              <div data-controller="endpoint"
                   data-endpoint-target="container"
                   data-endpoint-url-value="<%= project_endpoint_path(project_name: @project.name, id: endpoint.id, candidate: @candidate&.name) %>">
                <%= render "endpoints/endpoint_diff", endpoint: endpoint, previous_endpoint: endpoint.previous, expanded: false %>
              </div>
            <% elsif endpoint.annotation == "added" %>
              <div data-controller="endpoint"
                   data-endpoint-target="container"
                   data-endpoint-url-value="<%= project_endpoint_path(project_name: @project.name, id: endpoint.id, kind: 'new', candidate: @candidate&.name) %>">
                <%= render "endpoints/endpoint_new", endpoint: endpoint, expanded: false %>
              </div>
            <% elsif endpoint.annotation == "removed" %>
              <div data-controller="endpoint"
                   data-endpoint-target="container"
                   data-endpoint-url-value="<%= project_endpoint_path(project_name: @project.name, id: endpoint.id, kind: 'removed', candidate: @candidate&.name) %>">
                <%= render "endpoints/endpoint_removed", endpoint: endpoint, expanded: false %>
              </div>
            <% end %>
            <%= render "comments/anchor_region",
                  anchor: endpoint_anchor,
                  threads: comment_threads_for("endpoint", endpoint: endpoint, part: "whole"),
                  wrapper_class: endpoint.annotation == "removed" ? "mt-3 w-1/2 pr-1" : "mt-3 w-1/2 ml-auto pl-1" %>
          </div>
        <% end %>
      </div>
    <% end %>

    <%# Entities %>
    <% if @categorized_entities.any? %>
      <div class="text-xl font-semibold text-black uppercase tracking-wide mb-6 mt-8">Entities</div>
      <div class="flex flex-col gap-10">
        <% @categorized_entities.each do |entity| %>
          <% entity_anchor = CommentAnchor.new(scope: "entity", part: "whole", entity_name: entity.name) %>
          <div id="entity-<%= entity.name %>" <%= comment_region_attr(entity_anchor) %> data-sidebar-target="card" class="scroll-mt-6 rounded-xl">
            <% entity_line_comments = partition_line_comments(entity_root_comments(entity), entity.root, expanded: entity.annotation != "removed") %>
            <% if entity.annotation == "unchanged" || entity.annotation == "changed" %>
              <% diff = Diff::FromValues.new(entity.previous.parsed_root, entity.parsed_root) %>
              <%= render "versions/entity_diff", entity: entity, previous_entity: entity.previous, diff: diff, comments_by_line: entity_line_comments[:inline] %>
            <% elsif entity.annotation == "added" %>
              <% diff = entity.parsed_root.to_diff(:no_change) %>
              <%= render "versions/entity_added", entity: entity, diff: diff, comments_by_line: entity_line_comments[:inline] %>
            <% elsif entity.annotation == "removed" %>
              <% diff = entity.parsed_root.to_diff(:no_change) %>
              <%= render "versions/entity_removed", entity: entity, diff: diff %>
            <% end %>
            <%= render "comments/anchor_region",
                  anchor: entity_anchor,
                  threads: comment_threads_for("entity", entity: entity),
                  wrapper_class: entity.annotation == "removed" ? "mt-3 w-1/2 pr-1" : "mt-3 w-1/2 ml-auto pl-1" %>
            <%= render "comments/line_threads", collapsed: entity_line_comments[:collapsed], outdated: entity_line_comments[:outdated], wrapper_class: entity.annotation == "removed" ? "mt-3 w-1/2 pr-1" : "mt-3 w-1/2 ml-auto pl-1" %>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
