<div class="mb-6 flex items-center justify-between">
  <div>
    <div class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1"><%= @project.name %></div>
    <h1 class="text-2xl font-semibold text-gray-900"><%= @version.name %></h1>
    <div class="text-sm text-gray-500 mt-1"><%= @version.created_at.strftime("%Y-%m-%d") %></div>
  </div>

  <div class="flex items-center gap-3">
    <% if @previous_version.order > -1 %>
      <%= link_to "← #{@previous_version.name}", project_version_path(name: @previous_version.name, project_name: @previous_version.project.name, design: "v2"), class: "bg-white text-gray-700 border border-gray-300 text-sm font-medium px-4 py-2 rounded" %>
    <% else %>
      <span class="bg-gray-100 text-gray-400 text-sm font-medium px-4 py-2 rounded">←</span>
    <% end %>

    <% if @next_version.present? && @next_version.order > -1 %>
      <%= link_to "#{@next_version.name} →", project_version_path(name: @next_version.name, project_name: @next_version.project.name, design: "v2"), class: "bg-white text-gray-700 border border-gray-300 text-sm font-medium px-4 py-2 rounded" %>
    <% else %>
      <span class="bg-gray-100 text-gray-400 text-sm font-medium px-4 py-2 rounded">→</span>
    <% end %>

    <%= link_to "New candidate", new_project_candidate_path(project_name: @project.name, design: "v2"), class: "bg-sky-600 hover:bg-sky-700 text-white text-sm font-medium px-4 py-2 rounded" %>
  </div>
</div>

<%# Version column headers %>
<div class="grid grid-cols-2 gap-2 mb-6">
  <div class="bg-white border border-gray-200 rounded-lg p-4">
    <% if @previous_version.present? && @previous_version.order > -1 %>
      <div class="text-xs font-semibold text-gray-500 uppercase tracking-wide">Previous</div>
      <div class="text-lg font-semibold text-gray-900"><%= @previous_version.name %></div>
      <div class="text-sm text-gray-500"><%= @previous_version.created_at.strftime("%Y-%m-%d") %></div>
    <% else %>
      <div class="text-sm text-gray-400 italic">No previous version</div>
    <% end %>
  </div>
  <div class="bg-white border border-gray-200 rounded-lg p-4">
    <div class="text-xs font-semibold text-gray-500 uppercase tracking-wide">Current</div>
    <div class="text-lg font-semibold text-gray-900"><%= @version.name %></div>
    <div class="text-sm text-gray-500"><%= @version.created_at.strftime("%Y-%m-%d") %></div>
  </div>
</div>

<div class="flex gap-6 items-start">
  <aside class="w-64 shrink-0 self-start sticky top-6 max-h-screen overflow-y-auto bg-white border border-gray-200 rounded-lg p-4">
    <% if @categorized_endpoints.any? %>
      <div>
        <div class="text-xs font-semibold uppercase tracking-wide text-gray-500 mb-2">Endpoints</div>
        <% @categorized_endpoints.each do |endpoint| %>
          <% tint = { "added" => "text-emerald-700", "removed" => "text-red-700" }[endpoint.annotation] || "text-gray-700" %>
          <a href="<%= "#endpoint-#{endpoint.page_url}" %>"
             class="block px-2 py-1 rounded text-sm <%= tint %> hover:bg-gray-50 hover:text-sky-700 truncate">
            <%= endpoint.name %>
          </a>
        <% end %>
      </div>
    <% end %>

    <% if @categorized_entities.any? %>
      <div class="<%= "mt-4 pt-4 border-t border-gray-200" if @categorized_endpoints.any? %>">
        <div class="text-xs font-semibold uppercase tracking-wide text-gray-500 mb-2">Entities</div>
        <% @categorized_entities.each do |entity| %>
          <% tint = { "added" => "text-emerald-700", "removed" => "text-red-700" }[entity.annotation] || "text-gray-700" %>
          <a href="<%= "#entity-#{entity.name}" %>"
             class="block px-2 py-1 rounded text-sm <%= tint %> hover:bg-gray-50 hover:text-sky-700 truncate">
            <%= entity.name %>
          </a>
        <% end %>
      </div>
    <% end %>
  </aside>

  <div class="flex-1 min-w-0">
    <%# Endpoints %>
    <% if @categorized_endpoints.any? %>
      <div class="text-xl font-semibold text-black uppercase tracking-wide mb-3">Endpoints</div>
      <div class="flex flex-col gap-6">
        <% @categorized_endpoints.each do |endpoint| %>
          <div id="endpoint-<%= endpoint.page_url %>" class="scroll-mt-6 rounded-xl target:bg-amber-100 target:ring-4 target:ring-amber-400 target:p-3">
            <% if endpoint.annotation == "existing" %>
              <div data-controller="endpoint"
                   data-endpoint-target="container"
                   data-endpoint-url-value="<%= project_endpoint_path(project_name: @project.name, id: endpoint.id, design: 'v2') %>">
                <%= render "endpoints/endpoint_diff", endpoint: endpoint, previous_endpoint: endpoint.previous, expanded: false %>
              </div>
            <% elsif endpoint.annotation == "added" %>
              <%= render "endpoints/endpoint_new", endpoint: endpoint %>
            <% elsif endpoint.annotation == "removed" %>
              <%= render "endpoints/endpoint_removed", endpoint: endpoint %>
            <% end %>
          </div>
        <% end %>
      </div>
    <% end %>

    <%# Entities %>
    <% if @categorized_entities.any? %>
      <div class="text-xl font-semibold text-black uppercase tracking-wide mb-3 mt-8">Entities</div>
      <div class="flex flex-col gap-6">
        <% @categorized_entities.each do |entity| %>
          <div id="entity-<%= entity.name %>" class="scroll-mt-6 rounded-xl target:bg-amber-100 target:ring-4 target:ring-amber-400 target:p-3">
            <% if entity.annotation == "existing" %>
              <% diff = Diff::FromValues.new(entity.previous.parsed_root, entity.parsed_root) %>
              <%= render "versions/entity_diff", entity: entity, previous_entity: entity.previous, diff: diff %>
            <% elsif entity.annotation == "added" %>
              <% diff = entity.parsed_root.to_diff(:no_change) %>
              <%= render "versions/entity_added", entity: entity, diff: diff %>
            <% elsif entity.annotation == "removed" %>
              <% diff = entity.parsed_root.to_diff(:no_change) %>
              <%= render "versions/entity_removed", entity: entity, diff: diff %>
            <% end %>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
