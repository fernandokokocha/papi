<div class="flex items-start" data-controller="sidebar">
  <div data-sidebar-target="showButton"
       class="hidden sticky top-6 self-start w-0 shrink-0">
    <button type="button"
            data-action="sidebar#toggle"
            class="absolute -left-10 top-0 bg-white border border-gray-200 hover:bg-gray-50 text-gray-500 hover:text-sky-700 rounded-lg p-2 shadow-sm"
            title="Show quick access">»</button>
  </div>

  <aside data-sidebar-target="aside"
         class="relative w-fit max-w-64 shrink-0 self-start sticky top-6 mr-6 transition-all duration-200 ease-out">
    <button type="button"
            data-action="sidebar#toggle"
            class="absolute -left-10 top-0 bg-white border border-gray-200 hover:bg-gray-50 text-gray-500 hover:text-sky-700 rounded-lg p-2 shadow-sm"
            title="Hide quick access">«</button>
    <div class="max-h-screen overflow-x-hidden overflow-y-auto bg-white border border-gray-200 rounded-lg p-4">
    <% if @categorized_endpoints.any? %>
      <div>
        <div class="text-xs font-bold uppercase tracking-wide text-gray-700 mb-2">Endpoints</div>
        <% @categorized_endpoints.each do |endpoint| %>
          <% tint = { "added" => "bg-emerald-50 text-emerald-700 font-semibold", "removed" => "bg-red-50 text-red-700 font-semibold line-through" }[endpoint.annotation] || "text-gray-700" %>
          <a href="<%= "#endpoint-#{endpoint.page_url}" %>"
             class="block px-2 py-1 rounded text-sm <%= tint %> hover:bg-gray-50 hover:text-sky-700 truncate">
            <%= endpoint.name %>
          </a>
        <% end %>
      </div>
    <% end %>

    <% if @categorized_entities.any? %>
      <div class="<%= "mt-4 pt-4 border-t border-gray-200" if @categorized_endpoints.any? %>">
        <div class="text-xs font-bold uppercase tracking-wide text-gray-700 mb-2">Entities</div>
        <% @categorized_entities.each do |entity| %>
          <% tint = { "added" => "bg-emerald-50 text-emerald-700 font-semibold", "removed" => "bg-red-50 text-red-700 font-semibold line-through" }[entity.annotation] || "text-gray-700" %>
          <a href="<%= "#entity-#{entity.name}" %>"
             class="block px-2 py-1 rounded text-sm <%= tint %> hover:bg-gray-50 hover:text-sky-700 truncate">
            <%= entity.name %>
          </a>
        <% end %>
      </div>
    <% end %>
    </div>
  </aside>

  <div class="flex-1 min-w-0">
    <% if block_given? %>
      <%= yield %>
    <% end %>

    <%# Endpoints %>
    <% if @categorized_endpoints.any? %>
      <div class="text-xl font-semibold text-black uppercase tracking-wide mb-3">Endpoints</div>
      <div class="flex flex-col gap-6">
        <% @categorized_endpoints.each do |endpoint| %>
          <div id="endpoint-<%= endpoint.page_url %>" class="scroll-mt-6 rounded-xl target:bg-amber-100 target:ring-4 target:ring-amber-500">
            <% if endpoint.annotation == "existing" %>
              <div data-controller="endpoint"
                   data-endpoint-target="container"
                   data-endpoint-url-value="<%= project_endpoint_path(project_name: @project.name, id: endpoint.id, design: 'v2') %>">
                <%= render "endpoints/endpoint_diff", endpoint: endpoint, previous_endpoint: endpoint.previous, expanded: false %>
              </div>
            <% elsif endpoint.annotation == "added" %>
              <%= render "endpoints/endpoint_new", endpoint: endpoint %>
            <% elsif endpoint.annotation == "removed" %>
              <%= render "endpoints/endpoint_removed", endpoint: endpoint %>
            <% end %>
          </div>
        <% end %>
      </div>
    <% end %>

    <%# Entities %>
    <% if @categorized_entities.any? %>
      <div class="text-xl font-semibold text-black uppercase tracking-wide mb-3 mt-8">Entities</div>
      <div class="flex flex-col gap-6">
        <% @categorized_entities.each do |entity| %>
          <div id="entity-<%= entity.name %>" class="scroll-mt-6 rounded-xl target:bg-amber-100 target:ring-4 target:ring-amber-500">
            <% if entity.annotation == "existing" %>
              <% diff = Diff::FromValues.new(entity.previous.parsed_root, entity.parsed_root) %>
              <%= render "versions/entity_diff", entity: entity, previous_entity: entity.previous, diff: diff %>
            <% elsif entity.annotation == "added" %>
              <% diff = entity.parsed_root.to_diff(:no_change) %>
              <%= render "versions/entity_added", entity: entity, diff: diff %>
            <% elsif entity.annotation == "removed" %>
              <% diff = entity.parsed_root.to_diff(:no_change) %>
              <%= render "versions/entity_removed", entity: entity, diff: diff %>
            <% end %>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
