<%# Header %>
<div class="mb-6 flex items-center justify-between">
  <div>
    <div class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1"><%= @project.name %></div>
    <div class="flex items-center gap-3">
      <h1 class="text-2xl font-semibold text-gray-900"><%= @candidate.name %></h1>
      <% state_classes = case @candidate.aasm_state
         when "open"     then "bg-yellow-50 text-yellow-700 border border-yellow-200"
         when "merged"   then "bg-emerald-50 text-emerald-700 border border-emerald-200"
         when "rejected" then "bg-red-50 text-red-700 border border-red-200"
         end %>
      <span class="<%= state_classes %> text-xs font-semibold px-2.5 py-1 rounded-full"><%= @candidate.aasm_state.capitalize %></span>
    </div>
  </div>

  <% if @candidate.open? %>
    <div class="flex items-center gap-3">
      <%= button_to "Edit", edit_project_candidate_path(@project.name, @candidate.name), method: :get, class: "bg-white text-gray-700 border border-gray-300 hover:bg-gray-50 text-sm font-medium px-4 py-2 rounded cursor-pointer" %>
      <%= button_to "Reject", project_candidate_rejection_path(@project.name, @candidate.name), class: "bg-red-600 hover:bg-red-700 text-white text-sm font-medium px-4 py-2 rounded cursor-pointer" %>
      <%= button_to "Merge", project_candidate_merge_path(@project.name, @candidate.name), class: "bg-emerald-600 hover:bg-emerald-700 text-white text-sm font-medium px-4 py-2 rounded cursor-pointer" %>
    </div>
  <% end %>
</div>

<%= render "versions/endpoints_and_entities" do %>
  <%# Version column headers %>
  <div class="grid grid-cols-2 gap-2 mb-6">
    <div class="bg-white border border-gray-200 rounded-lg p-4">
      <% if @previous_version.present? && @previous_version.order > -1 %>
        <div class="text-xs font-semibold text-gray-500 uppercase tracking-wide">Base Version</div>
        <div class="text-lg font-semibold text-gray-900"><%= @previous_version.name %></div>
        <div class="text-sm text-gray-500"><%= @previous_version.created_at.strftime("%Y-%m-%d") %></div>
      <% else %>
        <div class="text-sm text-gray-400 italic">No base version</div>
      <% end %>
    </div>
    <div class="bg-white border border-gray-200 rounded-lg p-4">
      <% if @version.persisted? %>
        <div class="text-xs font-semibold text-gray-500 uppercase tracking-wide">Current Version</div>
        <div class="text-lg font-semibold text-gray-900"><%= @version.name %></div>
        <div class="text-sm text-gray-500"><%= @version.created_at.strftime("%Y-%m-%d") %></div>
      <% else %>
        <div class="text-sm text-gray-400 italic">No current version</div>
      <% end %>
    </div>
  </div>
<% end %>
