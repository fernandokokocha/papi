<div class="mb-8 flex items-center justify-between">
  <h1 class="text-2xl font-semibold text-gray-900"><%= @group.name %></h1>
  <%= button_to "New project", new_project_path(design: "v2"), method: :get, class: "bg-sky-600 hover:bg-sky-700 text-white text-sm font-medium px-4 py-2 rounded cursor-pointer" %>
</div>

<div class="flex flex-col gap-3">
  <% @projects.each do |project| %>
    <div class="bg-white border border-gray-200 rounded-lg p-6">

      <div class="flex items-center justify-between mb-6">
        <div class="flex items-center gap-4">
          <h2 class="text-lg font-semibold text-gray-900"><%= project.name %></h2>
          <% if (latest = project.versions.order({ order: "DESC" }).first) %>
            <%= link_to latest.name, project_version_path(name: latest.name, project_name: project.name, design: "v2"), class: "text-sm font-semibold text-sky-700 underline underline-offset-2 hover:text-sky-900" %>
          <% end %>
        </div>
        <% if project.can_create_candidate? %>
          <%= button_to "New candidate", new_project_candidate_path(project_name: project.name, design: "v2"), method: :get, class: "bg-sky-600 hover:bg-sky-700 text-white text-sm font-medium px-4 py-2 rounded cursor-pointer" %>
        <% else %>
          <button disabled class="bg-gray-100 text-gray-400 text-sm font-medium px-4 py-2 rounded cursor-not-allowed">New candidate</button>
        <% end %>
      </div>

      <div class="grid grid-cols-2 gap-6">

        <div>
          <h3 class="text-xs font-semibold text-gray-600 uppercase tracking-wide mb-4">Versions</h3>
          <% project.versions.order({ order: "DESC" }).each_with_index do |version, i| %>
            <%= link_to project_version_path(name: version.name, project_name: project.name, design: "v2"), class: "flex items-center justify-between px-4 py-2 rounded #{i.odd? ? 'bg-gray-50' : ''} hover:bg-gray-200 transition-colors" do %>
              <div class="flex items-center">
                <span class="text-sm font-semibold text-sky-700"><%= version.name %></span>
              </div>
              <span class="text-xs text-gray-500"><%= version.created_at.strftime("%Y-%m-%d") %></span>
            <% end %>
          <% end %>
        </div>

        <div>
          <h3 class="text-xs font-semibold text-gray-600 uppercase tracking-wide mb-4">Candidates</h3>
          <% project.candidates.order({ order: "DESC" }).each_with_index do |candidate, i| %>
            <%= link_to project_candidate_path(name: candidate.name, project_name: project.name, design: "v2"), class: "flex items-center justify-between px-4 py-2 rounded #{i.odd? ? 'bg-gray-50' : ''} hover:bg-gray-200 transition-colors" do %>
              <div class="flex items-center gap-4">
                <span class="text-sm font-semibold text-sky-700"><%= candidate.name %></span>
                <span class="text-xs font-semibold px-3 rounded-full <%= candidate.aasm_state == 'merged' ? 'bg-emerald-50 text-emerald-700 border border-emerald-200' : candidate.aasm_state == 'rejected' ? 'bg-red-50 text-red-700 border border-red-200' : 'bg-yellow-50 text-yellow-700 border border-yellow-200' %>"><%= candidate.aasm_state.capitalize %></span>
              </div>
              <span class="text-xs text-gray-500"><%= candidate.created_at.strftime("%Y-%m-%d") %></span>
            <% end %>
          <% end %>
        </div>

      </div>
    </div>
  <% end %>
</div>
