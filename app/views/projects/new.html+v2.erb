<div class="flex justify-center py-16">
  <div class="w-full max-w-sm bg-white border border-gray-200 rounded-lg p-8">
    <h1 class="text-2xl font-semibold text-gray-900 text-center mb-8">New Project</h1>

    <% if @project.errors.any? %>
      <div class="mb-4 px-4 py-3 bg-red-50 border border-red-200 text-red-700 rounded text-sm">
        <strong><%= pluralize(@project.errors.count, "error") %>:</strong>
        <ul class="mt-1 list-disc list-inside">
          <% @project.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <%= form_with model: @project do |form| %>
      <div class="mb-5">
        <%= form.label :group, "Group", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <div class="w-full bg-gray-50 border border-gray-300 rounded px-3 py-2 text-sm text-gray-500">
          <%= @project.group.name %>
          <%= form.hidden_field :group_id %>
        </div>
      </div>

      <div class="mb-6">
        <%= form.label :name, "Project Name", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= form.text_field :name,
              required: true, autofocus: true,
              placeholder: "Enter project name",
              class: "w-full bg-white border border-gray-300 rounded px-3 py-2 text-sm text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-sky-500" %>
      </div>

      <div class="flex items-center gap-3">
        <%= form.submit "Create Project", class: "bg-sky-600 hover:bg-sky-700 text-white font-medium py-2 px-4 rounded text-sm cursor-pointer" %>
        <%= link_to "Cancel", projects_path(design: "v2"), class: "text-sm text-gray-500 hover:text-gray-700" %>
      </div>
    <% end %>
  </div>
</div>
