<!DOCTYPE html>
<html lang="en">
  <head>
    <title><%= content_for(:title) || "Papi" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>

    <%= vite_client_tag %>
    <%= vite_javascript_tag "form.jsx" %>
  </head>

  <body class="min-h-screen bg-gray-50 text-gray-900">
    <header class="bg-sky-900">
      <div class="max-w-7xl mx-auto px-6 h-14 flex items-center justify-between">
        <%= link_to "Papi", root_path, class: "text-xl font-bold text-white hover:text-sky-200 no-underline" %>

        <% if Current.user %>
          <div class="flex items-center gap-4">
            <span class="text-white text-sm"><%= Current.user.email_address %></span>
            <%= button_to "Log out", session_path, method: :delete, class: "bg-sky-500 hover:bg-sky-400 text-white text-sm px-3 py-1.5 rounded cursor-pointer" %>
          </div>
        <% else %>
          <%= button_to "Log in", new_session_path, method: :get, class: "bg-sky-500 hover:bg-sky-400 text-white text-sm px-3 py-1.5 rounded cursor-pointer" %>
        <% end %>
      </div>
    </header>

    <main class="max-w-7xl mx-auto px-6 py-6">
      <%= yield %>
    </main>
  </body>
</html>
