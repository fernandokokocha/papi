<% responses_diff = DiffResponses::FromResponses.new([], endpoint.responses, expanded: expanded) %>
<div class="grid grid-cols-2 gap-2">
  <div></div>
  <div>
    <div class="border border-emerald-200 rounded-lg">
      <div class="sticky top-0 z-10 rounded-t-lg bg-emerald-700 text-white px-4 py-3 text-sm font-mono flex items-center justify-between">
        <%= render "endpoints/verb_path", verb: endpoint.verb, path: endpoint.path %>
        <div class="flex items-center gap-2 ml-4">
          <% if endpoint.responses.any? { |r| r.parsed_output.expandable? } %>
            <% if expanded %>
              <button type="button" data-action="endpoint#collapse" class="text-xs bg-white text-gray-700 border border-gray-300 hover:bg-gray-50 px-2.5 py-0.5 rounded cursor-pointer leading-none">Collapse</button>
            <% else %>
              <button type="button" data-action="endpoint#expand" class="text-xs bg-white text-gray-700 border border-gray-300 hover:bg-gray-50 px-2.5 py-0.5 rounded cursor-pointer leading-none">Expand</button>
            <% end %>
          <% end %>
        </div>
      </div>
      <div class="bg-gray-200 border-t border-gray-300 px-3 py-1.5 text-xs font-semibold text-black uppercase tracking-wide">Note</div>
      <% note_anchor = CommentAnchor.new(scope: "endpoint", part: "note", endpoint_path: endpoint.path, endpoint_http_verb: Endpoint.http_verbs[endpoint.http_verb]) %>
      <div <%= comment_region_attr(note_anchor) %> class="px-3 py-2 bg-white border-b border-gray-200 text-sm text-gray-700"><%= endpoint.note %></div>
      <%= render "comments/anchor_region",
            anchor: note_anchor,
            threads: comment_threads_for("endpoint", endpoint: endpoint, part: "note"),
            wrapper_class: "" %>
      <div class="bg-gray-200 border-t border-gray-300 px-3 py-1.5 text-xs font-semibold text-black uppercase tracking-wide">Responses</div>
      <div class="bg-white border-b border-gray-200"><%= render "specs/responses", lines: responses_diff.lines, side: :after, endpoint: endpoint, curl_verb: endpoint.verb, curl_path: endpoint.path, expanded: expanded %></div>
    </div>
  </div>
</div>
