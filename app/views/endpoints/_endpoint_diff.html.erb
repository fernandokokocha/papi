<% output1 = expanded ? previous_endpoint.parsed_output.expand : previous_endpoint.parsed_output %>
<% output2 = expanded ? endpoint.parsed_output.expand : endpoint.parsed_output %>
<% output_error1 = expanded ? previous_endpoint.parsed_output_error.expand : previous_endpoint.parsed_output_error %>
<% output_error2 = expanded ? endpoint.parsed_output_error.expand : endpoint.parsed_output_error %>
<% output_diff = Diff::FromValues.new(output1, output2) %>
<% output_error_diff = Diff::FromValues.new(output_error1, output_error2) %>
<% notes_diff = DiffText::FromNotes.new(previous_endpoint.note, endpoint.note) %>
<% responses_diff = DiffResponses::FromResponses.new(previous_endpoint.responses, endpoint.responses) %>
<% changed = endpoint.differs_from?(previous_endpoint) %>
<% border_class = changed ? "border-amber-200" : "border-gray-200" %>
<% header_class = changed ? "bg-amber-600" : "bg-sky-900" %>

<div class="grid grid-cols-2 gap-2">
  <div>
    <div class="border <%= border_class %> rounded-lg">
      <div class="sticky top-0 z-10 rounded-t-lg <%= header_class %> text-white px-4 py-3 text-sm font-mono">
        <%= previous_endpoint.name %>
      </div>
      <div class="bg-gray-200 border-t border-gray-300 px-3 py-1.5 text-xs font-semibold text-black uppercase tracking-wide">Note</div>
      <div class="px-3 py-2 bg-white border-b border-gray-200 text-sm text-gray-700"><%= render "specs/text", diff: notes_diff.before %></div>
      <div class="bg-gray-200 border-t border-gray-300 px-3 py-1.5 text-xs font-semibold text-black uppercase tracking-wide">Responses</div>
      <div class="pl-2 py-2 bg-white border-b border-gray-200"><%= render "specs/responses", diff: responses_diff.before %></div>
      <div class="bg-gray-200 border-t border-gray-300 px-3 py-1.5 text-xs font-semibold text-black uppercase tracking-wide">Output</div>
      <div class="pl-2 py-2 bg-white border-b border-gray-200"><%= render "specs/json", diff: output_diff.before %></div>
      <div class="bg-gray-200 border-t border-gray-300 px-3 py-1.5 text-xs font-semibold text-black uppercase tracking-wide">Output for Errors</div>
      <div class="pl-2 py-2 bg-white border-b border-gray-200"><%= render "specs/json", diff: output_error_diff.before %></div>
    </div>
  </div>
  <div>
    <div class="border <%= border_class %> rounded-lg">
      <div class="sticky top-0 z-10 rounded-t-lg <%= header_class %> text-white px-4 py-3 text-sm font-mono flex items-center justify-between"
           data-controller="clipboard"
           data-clipboard-verb-value="<%= endpoint.verb %>"
           data-clipboard-path-value="<%= endpoint.path %>">
        <span><%= endpoint.name %></span>
        <div class="flex items-center gap-2 ml-4">
          <button type="button" data-action="clipboard#copy" class="text-xs bg-white text-gray-700 border border-gray-300 hover:bg-gray-50 px-2.5 py-0.5 rounded cursor-pointer leading-none">Copy cURL</button>
          <% if endpoint.parsed_output.expandable? || endpoint.parsed_output_error.expandable? %>
            <% if expanded %>
              <button type="button" data-action="endpoint#collapse" class="text-xs bg-white text-gray-700 border border-gray-300 hover:bg-gray-50 px-2.5 py-0.5 rounded cursor-pointer leading-none">Collapse</button>
            <% else %>
              <button type="button" data-action="endpoint#expand" class="text-xs bg-white text-gray-700 border border-gray-300 hover:bg-gray-50 px-2.5 py-0.5 rounded cursor-pointer leading-none">Expand</button>
            <% end %>
          <% end %>
        </div>
      </div>
      <div class="bg-gray-200 border-t border-gray-300 px-3 py-1.5 text-xs font-semibold text-black uppercase tracking-wide">Note</div>
      <div class="px-3 py-2 bg-white border-b border-gray-200 text-sm text-gray-700"><%= render "specs/text", diff: notes_diff.after %></div>
      <div class="bg-gray-200 border-t border-gray-300 px-3 py-1.5 text-xs font-semibold text-black uppercase tracking-wide">Responses</div>
      <div class="pl-2 py-2 bg-white border-b border-gray-200"><%= render "specs/responses", diff: responses_diff.after %></div>
      <div class="bg-gray-200 border-t border-gray-300 px-3 py-1.5 text-xs font-semibold text-black uppercase tracking-wide">Output</div>
      <div class="pl-2 py-2 bg-white border-b border-gray-200"><%= render "specs/json", diff: output_diff.after %></div>
      <div class="bg-gray-200 border-t border-gray-300 px-3 py-1.5 text-xs font-semibold text-black uppercase tracking-wide">Output for Errors</div>
      <div class="pl-2 py-2 bg-white border-b border-gray-200"><%= render "specs/json", diff: output_error_diff.after %></div>
    </div>
  </div>
</div>
