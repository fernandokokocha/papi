<% notes_diff = DiffText::FromNotes.new(previous_endpoint.note, endpoint.note) %>
<% responses_diff = DiffResponses::FromResponses.new(previous_endpoint.responses, endpoint.responses, expanded: expanded) %>
<% changed = endpoint.differs_from?(previous_endpoint) %>
<% border_class = changed ? "border-amber-200" : "border-gray-200" %>
<% header_class = changed ? "bg-amber-600" : "bg-sky-900" %>
<% expandable = previous_endpoint.responses.any? { |r| r.parsed_output.expandable? } || endpoint.responses.any? { |r| r.parsed_output.expandable? } %>

<div class="border <%= border_class %> rounded-lg overflow-hidden">
  <%# Headers %>
  <div class="grid grid-cols-2 sticky top-0 z-10">
    <div class="<%= header_class %> text-white px-4 py-3 text-sm font-mono flex items-center gap-2">
      <%= render "endpoints/verb_badge", verb: previous_endpoint.verb %>
      <span class="truncate"><%= previous_endpoint.path %></span>
    </div>
    <div class="<%= header_class %> border-l border-white/20 text-white px-4 py-3 text-sm font-mono flex items-center justify-between">
      <span class="flex items-center gap-2 min-w-0">
        <%= render "endpoints/verb_badge", verb: endpoint.verb %>
        <span class="truncate"><%= endpoint.path %></span>
      </span>
      <div class="flex items-center gap-2 ml-4">
        <% if expandable %>
          <% if expanded %>
            <button type="button" data-action="endpoint#collapse" class="text-xs bg-white text-gray-700 border border-gray-300 hover:bg-gray-50 px-2.5 py-0.5 rounded cursor-pointer leading-none">Collapse</button>
          <% else %>
            <button type="button" data-action="endpoint#expand" class="text-xs bg-white text-gray-700 border border-gray-300 hover:bg-gray-50 px-2.5 py-0.5 rounded cursor-pointer leading-none">Expand</button>
          <% end %>
        <% end %>
      </div>
    </div>
  </div>

  <%# Note %>
  <div class="bg-gray-200 border-t border-gray-300 px-3 py-1.5 text-xs font-semibold text-black uppercase tracking-wide">Note</div>
  <div class="grid grid-cols-2">
    <div class="px-3 py-2 bg-white text-sm text-gray-700"><%= render "specs/text", diff: notes_diff.before %></div>
    <div class="px-3 py-2 bg-white border-l border-gray-200 text-sm text-gray-700"><%= render "specs/text", diff: notes_diff.after %></div>
  </div>

  <%# Responses — one grid row per code keeps both sides vertically aligned %>
  <div class="bg-gray-200 border-t border-gray-300 px-3 py-1.5 text-xs font-semibold text-black uppercase tracking-wide">Responses</div>
  <div class="grid grid-cols-2 gap-x-2 bg-white border-t border-gray-200">
    <% responses_diff.lines.each_with_index do |line, i| %>
      <% if i > 0 %><div class="col-span-2 border-t border-gray-200"></div><% end %>
      <%= render "endpoints/response_cell", line: line, side: :before %>
      <%= render "endpoints/response_cell", line: line, side: :after, curl_verb: endpoint.verb, curl_path: endpoint.path %>
    <% end %>
  </div>
</div>
